# Muxshed Configuration
# Copy this to .env and adjust as needed.

# API server listen address
MUXSHED_LISTEN_ADDR=0.0.0.0:8080

# RTMP ingest port
MUXSHED_RTMP_PORT=1935

# SQLite database path
MUXSHED_DB_PATH=muxshed.db

# Data directory for recordings, stingers, etc.
MUXSHED_DATA_DIR=data

# Log level (trace, debug, info, warn, error)
MUXSHED_LOG_LEVEL=info

# Rust log filter (overrides MUXSHED_LOG_LEVEL for Rust crates)
RUST_LOG=info
