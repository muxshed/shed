<Container version="2">
  <Name>Muxshed</Name>
  <Repository>ghcr.io/muxshed/shed:latest</Repository>
  <Registry>https://ghcr.io/muxshed/shed</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/muxshed/shed/issues</Support>
  <Project>https://github.com/muxshed/shed</Project>
  <Overview>
    Self-hosted live production studio. Ingest RTMP/SRT sources,
    mix and switch in a browser-based production switcher, and fan-out
    to unlimited destinations simultaneously. The open source alternative
    to Restream, StreamYard, and vMix.
  </Overview>
  <Category>MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <Icon>https://raw.githubusercontent.com/muxshed/shed/main/.github/images/2000px.png</Icon>
  <Config Name="Web UI" Target="8080" Default="8080" Mode="tcp" Description="Web UI and API" Type="Port" Display="always" Required="true">8080</Config>
  <Config Name="RTMP Ingest" Target="1935" Default="1935" Mode="tcp" Description="RTMP ingest port for OBS/encoders" Type="Port" Display="always" Required="true">1935</Config>
  <Config Name="SRT Ingest Start" Target="9000" Default="9000" Mode="udp" Description="First SRT port (per-source ports use 9000-9099 range)" Type="Port" Display="always" Required="false">9000</Config>
  <Config Name="Config" Target="/config" Default="/mnt/user/appdata/muxshed" Mode="rw" Description="Database and configuration" Type="Path" Display="always" Required="true">/mnt/user/appdata/muxshed</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/muxshed/data" Mode="rw" Description="Library assets, recordings, thumbnails" Type="Path" Display="always" Required="true">/mnt/user/appdata/muxshed/data</Config>
</Container>
