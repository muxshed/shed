<Container version="2">
  <Name>Muxshed</Name>
  <Repository>ghcr.io/muxshed/muxshed:latest</Repository>
  <Registry>https://ghcr.io/muxshed/muxshed</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/muxshed/muxshed/issues</Support>
  <Project>https://muxshed.com</Project>
  <Overview>
    Self-hosted live production studio. Ingest RTMP/SRT/WebRTC sources,
    mix and switch in a browser-based production switcher, and fan-out
    to unlimited destinations simultaneously.
  </Overview>
  <Category>MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <Icon>https://muxshed.com/icon.png</Icon>
  <Config Name="Web UI" Target="8080" Default="8080" Mode="tcp" Description="Web UI and API" Type="Port" Display="always" Required="true">8080</Config>
  <Config Name="RTMP Ingest" Target="1935" Default="1935" Mode="tcp" Description="RTMP ingest port for OBS/encoders" Type="Port" Display="always" Required="true">1935</Config>
  <Config Name="SRT Ingest" Target="9000" Default="9000" Mode="udp" Description="SRT ingest port" Type="Port" Display="always" Required="false">9000</Config>
  <Config Name="WebRTC Signalling" Target="8443" Default="8443" Mode="tcp" Description="WebRTC signalling port" Type="Port" Display="always" Required="false">8443</Config>
  <Config Name="Config" Target="/config" Default="/mnt/user/appdata/muxshed" Mode="rw" Description="Configuration and database" Type="Path" Display="always" Required="true">/mnt/user/appdata/muxshed</Config>
</Container>
